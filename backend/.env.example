# Environment Configuration - Development / Local
# Copy this file to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://tndb:tndb@localhost:5432/tndb
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ORIGINS=["http://localhost:3000","http://localhost:80","http://localhost:8001"]

DATA_DIR=./data
UPLOAD_DIR=./data/uploads
GENOME_DIR=./data/genomes
BLAST_DB_DIR=./data/blast_db
EXPORT_DIR=./data/exports
MAX_UPLOAD_SIZE=524288000

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=euTnDB
SMTP_USE_SSL=true
