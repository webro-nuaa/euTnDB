# China mirror — set to true to use Tsinghua mirrors for faster builds in China
# GitHub CI uses false (default) to avoid mirror failures
USE_CHINA_MIRROR=false

# Database
POSTGRES_USER=tndb
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tndb
DATABASE_URL=postgresql+asyncpg://tndb:change-me@db:5432/tndb
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Security — CHANGE THESE in production!
SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ORIGINS=["http://localhost","http://localhost:80","http://127.0.0.1","https://your-domain.com"]

# Data directories
DATA_DIR=/app/data
UPLOAD_DIR=/app/data/uploads
GENOME_DIR=/app/data/genomes
BLAST_DB_DIR=/app/data/blast_db
EXPORT_DIR=/app/data/exports

# Default admin credentials (only used on first startup)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Email (SMTP) — optional
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=euTnDB
SMTP_USE_SSL=true
